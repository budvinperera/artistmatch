<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ArtistMatch Chat</title>

<script src="/socket.io/socket.io.js"></script>

<style>

body{
    margin:0;
    font-family: "Segoe UI", Arial;
    background:#0f172a;
}

/* MAIN CONTAINER */
.chat-container{
    display:flex;
    height:100vh;
}

/* SIDEBAR */
.sidebar{
    width:30%;
    background:#020617;
    border-right:1px solid #1e293b;
    color:white;
}

.sidebar-header{
    padding:20px;
    font-size:20px;
    font-weight:bold;
    border-bottom:1px solid #1e293b;
}

.user{
    padding:15px 20px;
    cursor:pointer;
    border-bottom:1px solid #1e293b;
}

.user:hover{
    background:#0f172a;
}

/* CHAT AREA */
.chat-area{
    width:70%;
    display:flex;
    flex-direction:column;
}

/* HEADER */
.chat-header{
    padding:20px;
    background:#020617;
    color:white;
    border-bottom:1px solid #1e293b;
}

/* MESSAGES */
.messages{
    flex:1;
    padding:20px;
    overflow-y:auto;
    background:#020617;
}

.message{
    padding:10px 15px;
    margin:10px;
    border-radius:10px;
    max-width:60%;
}

.sent{
    background:#3b82f6;
    color:white;
    margin-left:auto;
}

.received{
    background:#1e293b;
    color:white;
}

/* INPUT */
.chat-input{
    display:flex;
    padding:15px;
    background:#020617;
    border-top:1px solid #1e293b;
}

.chat-input input{
    flex:1;
    padding:12px;
    border-radius:8px;
    border:none;
    outline:none;
}

.chat-input button{
    margin-left:10px;
    padding:12px 20px;
    border:none;
    border-radius:8px;
    background:#3b82f6;
    color:white;
    cursor:pointer;
}

.chat-input button:hover{
    background:#2563eb;
}

</style>
</head>

<body>

<div class="chat-container">

    <!-- SIDEBAR -->
    <div class="sidebar">

        <div class="sidebar-header">
            ArtistMatch
        </div>

        <div class="user" onclick="selectUser(2)">
            🎤 Artist 2
        </div>

        <div class="user" onclick="selectUser(3)">
            🎧 Artist 3
        </div>

    </div>


    <!-- CHAT AREA -->
    <div class="chat-area">

        <div class="chat-header">
            Chat
        </div>

        <div class="messages" id="messages">
        </div>

        <div class="chat-input">

            <input
                type="text"
                id="messageInput"
                placeholder="Type your message..."
            >

            <button onclick="sendMessage()">
                Send
            </button>

        </div>

    </div>

</div>


<script>

const socket = io();

let currentUser = prompt("Enter your user ID (example: 1 or 2)");
let otherUser = currentUser == 1 ? 2 : 1;



// receive real-time message
socket.on("receiveMessage", (data)=>{

    const box = document.getElementById("messages");

    const div = document.createElement("div");

    div.classList.add("message");

    if(data.sender_id == currentUser)
        div.classList.add("sent");
    else
        div.classList.add("received");

    div.innerText = data.message;

    box.appendChild(div);

    box.scrollTop = box.scrollHeight;

});


// send message
function sendMessage(){

    const input = document.getElementById("messageInput");

    const message = input.value;

    if(message.trim()=="") return;

    socket.emit("sendMessage", {

        sender_id: currentUser,
        receiver_id: otherUser,
        message: message

    });

    input.value="";

}


// select user
function selectUser(id){

    otherUser = id;

    document.getElementById("messages").innerHTML="";

}

</script>

</body>
</html>
