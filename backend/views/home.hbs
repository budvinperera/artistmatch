<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
</head>
<body>
    <h1>Welcome to ArtistMatch</h1>

    <form action="/search" method="GET">
        <input type="text" name="artistName" placeholder="Search for an artist" required>
        <button type="submit">Search</button>
    </form>

    {{#if artists}}
    <h2>Search Results:</h2>
    <ul>
        {{#each artists}}
            <li>{{this.artist_name}} - {{this.genre_name}}</li>
        {{/each}}
    </ul>
    {{/if}}

    {{#if message}}
        <p>{{message}}</p>
    {{/if}}

    <h2>Trending Genres</h2>
<ul>
  {{#each trendingGenres}}
    <li>{{this.name}}</li>
  {{/each}}
</ul>

<h2>Suggested Artists</h2>
<ul>
  {{#each suggestedArtists}}
    <li>{{this.name}}</li>
  {{/each}}
</ul>

<h2>New Releases</h2>
<ul>
  {{#each newReleases}}
    <li>{{this.title}} - {{this.artist_name}}</li>
  {{/each}}
</ul>

</body>
</html>
